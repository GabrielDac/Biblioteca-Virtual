{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Biblioteca Virtual",
  "version": "1.0.0",
  "identifier": "com.gabrieldacosta.bibliotecavirtual",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Biblioteca Virtual",
        "width": 1240,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Biblioteca virtual de libros digitales",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
